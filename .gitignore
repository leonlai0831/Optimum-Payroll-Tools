# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright
/test-results/
/playwright-report/
/playwright/.cache/
dev.log

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# local dev database (PGlite fallback)
/.pglite

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# gstack browse tooling (local QA artifacts: logs, tokens, pids)
.gstack/

# Playwright e2e output (uploaded as CI artifacts, never committed)
/test-results/
/playwright-report/
